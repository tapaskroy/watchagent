# Local API dev with staging-like CORS (copy to apps/api/.env if testing against staging web):
#   cp apps/api/.env.staging.example apps/api/.env
# For full local stack, use apps/api/.env.example instead.

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

DB_HOST=localhost
DB_PORT=5432
DB_NAME=watchagent
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_POOL_SIZE=20

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_ACCESS_SECRET=your-super-secret-access-token-key-min-32-chars-long
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-min-32-chars-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

TMDB_API_KEY=your_tmdb_api_key_here
OMDB_API_KEY=your_omdb_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

CORS_ORIGIN=https://staging.watchagent.tapaskroy.me,http://localhost:3001

RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

LOG_LEVEL=info
