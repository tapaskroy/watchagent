# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=watchagent
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_POOL_SIZE=20

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_ACCESS_SECRET=your-super-secret-access-token-key-min-32-chars-long
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-min-32-chars-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# External API Keys
TMDB_API_KEY=your_tmdb_api_key_here
OMDB_API_KEY=your_omdb_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google OAuth (create credentials at console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id_here

# Email — AWS SES (verify sending domain in SES before use)
EMAIL_FROM_ADDRESS=noreply@watchagent.tapaskroy.me
EMAIL_FROM_NAME=WatchAgent
AWS_SES_REGION=us-east-1

# Avatar S3 bucket
AVATAR_S3_BUCKET=watchagent-prod-avatars

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:19006

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# Logging
LOG_LEVEL=info
