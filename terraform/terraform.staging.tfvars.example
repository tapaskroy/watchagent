# Staging infrastructure — copy to terraform.staging.tfvars and apply:
#   cp terraform.staging.tfvars.example terraform.staging.tfvars
#   export TF_VAR_tmdb_api_key="..." TF_VAR_omdb_api_key="..." TF_VAR_anthropic_api_key="..."
#   terraform apply -var-file=terraform.staging.tfvars
#
# URLs after apply:
#   Web: https://watchagent-staging.tapaskroy.me
#   API: https://api.watchagent-staging.tapaskroy.me

aws_region  = "us-east-1"
environment = "staging"

# Must differ from prod (watchagent) to avoid Route53 / ACM conflicts
domain_name = "tapaskroy.me"
subdomain   = "watchagent-staging"

# Database — smaller than prod; non-prod uses single-AZ in rds.tf
db_instance_class    = "db.t3.micro"
db_allocated_storage = 20

# Redis
redis_node_type       = "cache.t3.micro"
redis_num_cache_nodes = 1

# ECS — single task per service for staging
api_cpu            = 512
api_memory         = 1024
api_desired_count  = 1

web_cpu            = 512
web_memory         = 1024
web_desired_count  = 1

# Auto Scaling
api_autoscaling_min = 1
api_autoscaling_max = 2

web_autoscaling_min = 1
web_autoscaling_max = 2

# API keys — do not commit real values. Use environment variables:
#   export TF_VAR_tmdb_api_key="..."
#   export TF_VAR_omdb_api_key="..."
#   export TF_VAR_anthropic_api_key="..."

# tmdb_api_key      = ""
# omdb_api_key      = ""
# anthropic_api_key = ""
